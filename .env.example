# ── Harness Authentication ──────────────────────────────────────────────────
# Use ONE of the following auth methods:

# Option 1 (recommended): Personal Access Token or Service Account Token
# Format: pat.<accountId>.<tokenId>.<secret>  — accountId auto-extracted.
HARNESS_API_KEY=pat.xxxx.xxxx.xxxx

# Option 2: Bearer token (session JWT from browser DevTools)
# HARNESS_BEARER_TOKEN=<YOUR_BEARER_TOKEN_HERE>

# ── Account & Scope ─────────────────────────────────────────────────────────
# Required when NOT using a PAT (which embeds the account ID).
# HARNESS_ACCOUNT_ID=your_account_id

# Default org/project to use when not specified per-request.
HARNESS_DEFAULT_ORG_ID=default
HARNESS_DEFAULT_PROJECT_ID=

# ── Server ──────────────────────────────────────────────────────────────────
HARNESS_BASE_URL=https://app.harness.io

# HTTP transport port — three ways to set it (highest priority wins):
#   1. --port flag:   node build/index.js http --port 8080
#   2. PORT env var:  PORT=8080 node build/index.js http
#   3. Default:       3000
PORT=3000

# Bind address for HTTP transport (default: 127.0.0.1 = localhost only).
# Set to 0.0.0.0 to accept connections from any interface (e.g. inside Docker).
HOST=127.0.0.1

# ── Tuning ──────────────────────────────────────────────────────────────────
HARNESS_API_TIMEOUT_MS=30000
HARNESS_MAX_RETRIES=3
HARNESS_RATE_LIMIT_RPS=10
LOG_LEVEL=info

# Set to true to block all write operations (create/update/delete/run).
HARNESS_READ_ONLY=false
