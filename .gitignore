# Dependencies
node_modules/

# Build output
build/

# Environment / secrets — never commit
.env
.env.local
.env.*.local
mcp.json

# Customer-facing BVR artifacts — never commit per-customer reports.
# All paths under reports/ are ignored by default. To ship an anonymised
# sample alongside the source code, opt-in by uncommenting the example
# allow-list below and adding files under reports/example/.
reports/*
!reports/example/
!reports/example/**
!reports/.gitkeep

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# OS
Thumbs.db
